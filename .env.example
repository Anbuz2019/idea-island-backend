# Database
MYSQL_ROOT_PASSWORD=
DB_NAME=idea_island
DB_USERNAME=app
DB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Docker compose project and persistent volumes
COMPOSE_PROJECT_NAME=idea-island
MYSQL_VOLUME_NAME=idea-island_mysql_data
REDIS_VOLUME_NAME=idea-island_redis_data
APP_LOGS_VOLUME_NAME=idea-island_app_logs
APP_DATA_LOGS_VOLUME_NAME=idea-island_app_data_logs

# JWT
JWT_SECRET=

# COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_BASE_URL=

# LinkPreview fallback for link title/description/cover extraction
LINKPREVIEW_ENABLED=false
LINKPREVIEW_API_KEY=
LINKPREVIEW_ENDPOINT=https://api.linkpreview.net
LINKPREVIEW_TIMEOUT_MS=8000

# Bilibili public API preview extraction
BILIBILI_PREVIEW_ENABLED=true
BILIBILI_PREVIEW_TIMEOUT_MS=8000

# Missing cover backfill job
JOB_TIMEZONE=Asia/Shanghai
COVER_BACKFILL_CRON=0 */1 * * * *
COVER_BACKFILL_LIMIT=50

# XXL-Job
XXL_JOB_ADMIN_URL=http://xxl-job-admin:8080/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=
