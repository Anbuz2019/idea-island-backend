<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.anbuz.infrastructure.persistent.dao.ITopicDao">

    <resultMap id="topicMap" type="com.anbuz.infrastructure.persistent.po.TopicPO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="materialCount" column="material_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO topic (user_id, name, description, status, material_count, created_at, updated_at)
        VALUES (#{userId}, #{name}, #{description}, #{status}, #{materialCount}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update">
        UPDATE topic
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="materialCount != null">material_count = #{materialCount},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM topic WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="topicMap">
        SELECT * FROM topic WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="topicMap">
        SELECT * FROM topic WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="countByUserIdAndName" resultType="int">
        SELECT COUNT(1) FROM topic WHERE user_id = #{userId} AND name = #{name}
    </select>

    <select id="countByUserId" resultType="long">
        SELECT COUNT(1) FROM topic WHERE user_id = #{userId}
    </select>

</mapper>
