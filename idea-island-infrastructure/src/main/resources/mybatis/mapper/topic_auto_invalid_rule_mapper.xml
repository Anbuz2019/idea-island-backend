<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.anbuz.infrastructure.persistent.dao.ITopicAutoInvalidRuleDao">

    <resultMap id="ruleMap" type="com.anbuz.infrastructure.persistent.po.TopicAutoInvalidRulePO">
        <id property="id" column="id"/>
        <result property="topicId" column="topic_id"/>
        <result property="ruleType" column="rule_type"/>
        <result property="thresholdDays" column="threshold_days"/>
        <result property="isEnabled" column="is_enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectEnabledRules" resultMap="ruleMap">
        SELECT *
        FROM topic_auto_invalid_rule
        WHERE is_enabled = 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO topic_auto_invalid_rule (topic_id, rule_type, threshold_days, is_enabled, created_at, updated_at)
        VALUES (#{topicId}, #{ruleType}, #{thresholdDays}, #{isEnabled}, #{createdAt}, #{updatedAt})
    </insert>

    <delete id="deleteByTopicId">
        DELETE FROM topic_auto_invalid_rule WHERE topic_id = #{topicId}
    </delete>

</mapper>
