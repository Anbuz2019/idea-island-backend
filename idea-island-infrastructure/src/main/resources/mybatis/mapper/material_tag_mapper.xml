<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.anbuz.infrastructure.persistent.dao.IMaterialTagDao">

    <resultMap id="tagMap" type="com.anbuz.infrastructure.persistent.po.MaterialTagPO">
        <id property="id" column="id"/>
        <result property="materialId" column="material_id"/>
        <result property="tagType" column="tag_type"/>
        <result property="tagGroupKey" column="tag_group_key"/>
        <result property="tagValue" column="tag_value"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insertBatch">
        INSERT INTO material_tag (material_id, tag_type, tag_group_key, tag_value, created_at)
        VALUES
        <foreach collection="tags" item="tag" separator=",">
            (#{tag.materialId}, #{tag.tagType}, #{tag.tagGroupKey}, #{tag.tagValue}, #{tag.createdAt})
        </foreach>
    </insert>

    <delete id="deleteByMaterialId">
        DELETE FROM material_tag WHERE material_id = #{materialId}
    </delete>

    <delete id="deleteByMaterialIdAndTagType">
        DELETE FROM material_tag WHERE material_id = #{materialId} AND tag_type = #{tagType}
    </delete>

    <delete id="deleteByMaterialIdAndGroupKey">
        DELETE FROM material_tag WHERE material_id = #{materialId} AND tag_group_key = #{tagGroupKey}
    </delete>

    <select id="selectByMaterialId" resultMap="tagMap">
        SELECT * FROM material_tag WHERE material_id = #{materialId}
    </select>

    <select id="selectByMaterialIdAndTagType" resultMap="tagMap">
        SELECT * FROM material_tag WHERE material_id = #{materialId} AND tag_type = #{tagType}
    </select>

</mapper>
